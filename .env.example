# ─────────────────────────────────────────────────────────────────────────────
# Modular Entity System — environment variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Django core
DJANGO_SETTINGS_MODULE=modular_entity_system.settings.development
SECRET_KEY=0+-*3fs-1t5unz98721+xxw6hrq1v327fkr9%od$k3tjldb=9&
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# Database (SQLite default — change ENGINE for PostgreSQL in production)
DATABASE_URL=sqlite:///db.sqlite3

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Pagination
PAGE_SIZE=20

# API throttling (requests per minute for anon / authenticated)
THROTTLE_ANON=100
THROTTLE_USER=1000

# Logging level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=DEBUG
